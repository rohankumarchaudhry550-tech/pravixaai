<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Admin Settings | Pravixa AI</title><link rel="icon" href="/fa.png"><style>body{margin:0;font-family:Inter,Arial,sans-serif;background:#07111d;color:#eef7ff}.app{display:grid;grid-template-columns:260px 1fr;min-height:100vh}.sidebar{background:#081827;padding:24px}.brand{display:flex;gap:12px;align-items:center;margin-bottom:28px}.brand img{height:42px}.nav{display:grid;gap:8px}.nav a{color:#bcd0e5;text-decoration:none;padding:12px 14px;border-radius:12px}.nav a.active,.nav a:hover{background:rgba(0,200,150,.14);color:#fff}.main{padding:28px}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px}.card{background:#0d1d31;border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:18px}.muted{color:#98adc3}.value{font-size:1.5rem;font-weight:800;margin-top:8px}@media(max-width:900px){.app{grid-template-columns:1fr}.main{padding:18px}}</style></head><body><div class="app"><aside class="sidebar"><div class="brand"><img src="/logo.png" alt="Pravixa AI Logo"><strong></strong></div><nav class="nav"><a href="/admin/dashboard">Dashboard</a><a href="/admin/contacts">Leads</a><a href="/admin/applications">Applications</a><a href="/admin/users">Users</a><a href="/admin/logs">Logs</a><a class="active" href="/admin/settings">Settings</a><a href="/admin/logout">Logout</a></nav></aside><main class="main"><h1>Settings</h1><p class="muted">Production configuration summary. Sensitive values are not displayed.</p><section class="grid"><div class="card"><div class="muted">Environment</div><div class="value"><%= settings.environment %></div></div><div class="card"><div class="muted">Session expiry</div><div class="value"><%= settings.sessionMinutes %> min</div></div><div class="card"><div class="muted">Admins</div><div class="value"><%= settings.adminsConfigured %></div></div><div class="card"><div class="muted">Max upload</div><div class="value"><%= settings.maxUploadMb %> MB</div></div></section></main></div></body></html>
