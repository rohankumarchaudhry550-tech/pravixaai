<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= project.title %> Case Study | Pravixa AI</title>
  <meta name="description" content="<%= project.summary %>">
  <link rel="canonical" href="https://globalaisolutions.com/portfolio/<%= slug %>">
    <link rel="icon" href="fa.png" type="image/png">

  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Inter, Arial, sans-serif;
      background: #070d19;
      color: #eef7ff;
      overflow-x: hidden;
    }

    /* HEADER */
    header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(8,24,39,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .nav {
      max-width: 1120px;
      margin: auto;
      padding: 16px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 800;
      color: #fff;
      text-decoration: none;
    }

    .brand img {
      height: 36px;
    }

    .links {
      display: flex;
      gap: 20px;
    }

    .links a {
      color: #cde2f5;
      text-decoration: none;
      font-size: 0.95rem;
      position: relative;
    }

    .links a::after {
      content: "";
      position: absolute;
      width: 0%;
      height: 2px;
      bottom: -4px;
      left: 0;
      background: #00c896;
      transition: 0.3s;
    }

    .links a:hover::after {
      width: 100%;
    }

    /* HAMBURGER */
    .menu-toggle {
      display: none;
      width: 28px;
      height: 22px;
      cursor: pointer;
      position: relative;
    }

    .menu-toggle span {
      position: absolute;
      width: 100%;
      height: 3px;
      background: #fff;
      transition: 0.3s;
    }

    .menu-toggle span:nth-child(1){top:0;}
    .menu-toggle span:nth-child(2){top:9px;}
    .menu-toggle span:nth-child(3){top:18px;}

    .menu-toggle.active span:nth-child(1){
      transform: rotate(45deg);
      top:9px;
    }
    .menu-toggle.active span:nth-child(2){
      opacity:0;
    }
    .menu-toggle.active span:nth-child(3){
      transform: rotate(-45deg);
      top:9px;
    }

    /* MOBILE MENU */
    .mobile-menu {
      position: fixed;
      top: 0;
      right: -100%;
      width: 260px;
      height: 100vh;
      background: rgba(8,24,39,0.96);
      backdrop-filter: blur(16px);
      padding: 80px 20px;
      display: flex;
      flex-direction: column;
      gap: 18px;
      transition: 0.35s ease;
      z-index: 999;
    }

    .mobile-menu.active {
      right: 0;
    }

    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);
      opacity: 0;
      visibility: hidden;
      transition: 0.3s;
    }

    .overlay.active {
      opacity: 1;
      visibility: visible;
    }

    /* MAIN */
    main {
      max-width: 1120px;
      margin: auto;
      padding: 70px 20px;
    }

    .eyebrow {
      color: #00c896;
      font-weight: 700;
      font-size: 0.8rem;
      text-transform: uppercase;
    }

    h1 {
      font-size: clamp(2rem,5vw,4rem);
      margin: 10px 0 16px;
    }

    .summary {
      max-width: 800px;
      color: #bdd0e5;
      margin-bottom: 30px;
    }

    /* GRID */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit,minmax(260px,1fr));
      gap: 18px;
    }

    .panel {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(0,200,150,0.18);
      border-radius: 16px;
      padding: 20px;
      transition: 0.25s;
    }

    .panel:hover {
      transform: translateY(-4px);
      border-color: #00c896;
    }

    h2 {
      color: #00c896;
      margin-bottom: 8px;
    }

    .tags {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .tag {
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(0,200,150,0.12);
      font-size: 0.85rem;
    }

    /* BUTTONS */
    .actions {
      margin: 30px 0;
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .btn {
      padding: 12px 18px;
      border-radius: 10px;
      text-decoration: none;
      font-weight: 700;
    }

    .primary {
      background: linear-gradient(135deg,#00c896,#007bff);
      color: white;
    }

    .secondary {
      border: 1px solid rgba(255,255,255,0.2);
      color: #dbeaff;
    }

    footer {
      text-align: center;
      padding: 20px;
      color: #8fa7bd;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    /* 🔥 MOBILE */
    @media (max-width: 490px) {

      .links {
        display: none;
      }

      .menu-toggle {
        display: block;
      }

      main {
        padding: 50px 16px;
        text-align: center;
      }

      .actions {
        flex-direction: column;
      }

      .btn {
        width: 100%;
        text-align: center;
      }
    }
  </style>
</head>

<body>

<header>
  <nav class="nav">
    <a class="brand" href="/">
      <img src="/logo.png">
    </a>

    <div class="links">
      <a href="/">Home</a>
      <a href="/services">Services</a>
      <a href="/portfolio">Portfolio</a>
      <a href="/careers">Careers</a>
      <a href="/contact">Contact</a>
      <a href="/admin">Admin</a>
    </div>

    <div class="menu-toggle" onclick="toggleMenu()" id="menuBtn">
      <span></span><span></span><span></span>
    </div>
  </nav>
</header>

<div class="mobile-menu" id="mobileMenu">
  <a href="/">Home</a>
  <a href="/services">Services</a>
  <a href="/portfolio">Portfolio</a>
  <a href="/careers">Careers</a>
  <a href="/contact">Contact</a>
  <a href="/admin">Admin</a>
</div>

<div class="overlay" id="overlay" onclick="toggleMenu()"></div>

<main>

  <div class="eyebrow"><%= project.category %> Case Study</div>
  <h1><%= project.title %></h1>
  <p class="summary"><%= project.summary %></p>

  <div class="grid">
    <section class="panel"><h2>Problem</h2><p><%= project.problem %></p></section>
    <section class="panel"><h2>Solution</h2><p><%= project.solution %></p></section>
    <section class="panel"><h2>Result</h2><p><%= project.result %></p></section>
  </div>

  <section class="panel">
    <h2>Technology Stack</h2>
    <div class="tags">
      <% project.stack.forEach(item => { %>
        <span class="tag"><%= item %></span>
      <% }) %>
    </div>
  </section>

  <div class="actions">
    <a class="btn primary" href="/contact">Start a Similar Project</a>
    <a class="btn secondary" href="/portfolio">Back to Portfolio</a>
  </div>

  <section class="panel">
    <h2>More Case Studies</h2>
    <% relatedProjects.forEach(item => { %>
      <p><a href="/portfolio/<%= item.slug %>"><%= item.title %></a></p>
    <% }) %>
  </section>

</main>

<footer>© 2026 Pravixa AI</footer>

<script>
function toggleMenu(){
  document.getElementById("mobileMenu").classList.toggle("active");
  document.getElementById("overlay").classList.toggle("active");
  document.getElementById("menuBtn").classList.toggle("active");
}
</script>

</body>
</html>