<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | Pravixa AI</title>
  <link rel="icon" href="/fa.png" type="image/png">
  <style>
    *{box-sizing:border-box}body{margin:0;font-family:Inter,Arial,sans-serif;background:#07111d;color:#eef7ff}.app{display:grid;grid-template-columns:260px 1fr;min-height:100vh}.sidebar{background:#081827;border-right:1px solid rgba(255,255,255,.08);padding:24px;position:sticky;top:0;height:100vh}.brand{display:flex;gap:12px;align-items:center;margin-bottom:28px}.brand img{height:42px}.nav{display:grid;gap:8px}.nav a{color:#bcd0e5;text-decoration:none;padding:12px 14px;border-radius:12px}.nav a.active,.nav a:hover{background:rgba(0,200,150,.14);color:#fff}.main{padding:28px;min-width:0}.top{display:flex;justify-content:space-between;gap:16px;align-items:center;margin-bottom:24px}.top h1{margin:0;font-size:2rem}.muted{color:#98adc3}.button{display:inline-flex;padding:10px 14px;border-radius:10px;background:#00c896;color:#06111d;text-decoration:none;font-weight:800}.grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:16px}.card,.panel{background:#0d1d31;border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:18px;box-shadow:0 18px 50px rgba(0,0,0,.18)}.kpi{font-size:2rem;font-weight:800;margin:8px 0;color:#fff}.charts{display:grid;grid-template-columns:1.4fr .9fr;gap:16px;margin:18px 0}.section-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}table{width:100%;border-collapse:collapse}th,td{padding:12px;border-bottom:1px solid rgba(255,255,255,.08);text-align:left;vertical-align:top}th{color:#9fb5ca;font-size:.82rem;text-transform:uppercase}.error{padding:12px 14px;border-radius:12px;background:rgba(255,91,91,.15);border:1px solid rgba(255,91,91,.3);color:#ffcaca;margin-bottom:16px}canvas{width:100%;height:260px}@media(max-width:900px){.app{grid-template-columns:1fr}.sidebar{position:relative;height:auto}.grid,.charts,.section-grid{grid-template-columns:1fr}.main{padding:18px}.top{align-items:flex-start;flex-direction:column}}
  </style>
</head>
<body>
  <div class="app">
    <aside class="sidebar">
      <div class="brand"><img src="/logo.png" alt="Pravixa AI Logo"><strong>Pravixa AI</strong></div>
      <nav class="nav">
        <a class="active" href="/admin/dashboard">Dashboard</a>
        <a href="/admin/contacts">Leads</a>
        <a href="/admin/applications">Applications</a>
        <a href="/admin/users">Users</a>
        <a href="/admin/logs">Logs</a>
        <a href="/admin/settings">Settings</a>
        <a href="/admin/logout">Logout</a>
      </nav>
    </aside>
    <main class="main">
      <div class="top">
        <div>
          <h1>Investor-Ready Dashboard</h1>
          <div class="muted">Live business overview, refreshed from secured backend data.</div>
        </div>
        <a class="button" href="/admin/dashboard">Refresh Data</a>
      </div>
      <% if (typeof error !== 'undefined' && error) { %><div class="error"><%= error %></div><% } %>
      <section class="grid">
        <div class="card"><div class="muted">Leads</div><div class="kpi"><%= stats.leads %></div><div class="muted">Contact submissions</div></div>
        <div class="card"><div class="muted">Calls</div><div class="kpi"><%= stats.calls %></div><div class="muted">Leads with phone</div></div>
        <div class="card"><div class="muted">Cost Saved</div><div class="kpi">$<%= stats.costSaved.toLocaleString() %></div><div class="muted">Estimated automation value</div></div>
        <div class="card"><div class="muted">Conversion Rate</div><div class="kpi"><%= stats.conversionRate %>%</div><div class="muted">Applications vs leads</div></div>
      </section>
      <section class="charts">
        <div class="panel"><h2>Lead Trend</h2><canvas id="lineChart" width="720" height="300"></canvas></div>
        <div class="panel"><h2>Service Mix</h2><canvas id="pieChart" width="360" height="300"></canvas></div>
      </section>
      <section class="section-grid">
        <div class="panel">
          <h2>Recent Leads</h2>
          <% if (recentContacts.length === 0) { %><p class="muted">No leads yet.</p><% } else { %>
          <table><thead><tr><th>Name</th><th>Email</th><th>Service</th></tr></thead><tbody>
          <% recentContacts.forEach(contact => { %><tr><td><%= contact.name %></td><td><%= contact.email %></td><td><%= contact.service || 'Not specified' %></td></tr><% }) %>
          </tbody></table><% } %>
        </div>
        <div class="panel">
          <h2>Recent Applications</h2>
          <% if (recentApplications.length === 0) { %><p class="muted">No applications yet.</p><% } else { %>
          <table><thead><tr><th>Name</th><th>Email</th><th>Role</th></tr></thead><tbody>
          <% recentApplications.forEach(application => { %><tr><td><%= application.name %></td><td><%= application.email %></td><td><%= application.role %></td></tr><% }) %>
          </tbody></table><% } %>
        </div>
        <div class="panel">
          <h2>Recent Signups</h2>
          <% if (!recentUsers || recentUsers.length === 0) { %><p class="muted">No customer accounts yet.</p><% } else { %>
          <table><thead><tr><th>Name</th><th>Email</th><th>Company</th></tr></thead><tbody>
          <% recentUsers.forEach(user => { %><tr><td><%= user.name %></td><td><%= user.email %></td><td><%= user.company || 'Not specified' %></td></tr><% }) %>
          </tbody></table><% } %>
        </div>
      </section>
    </main>
  </div>
  <script>
    const stats = <%- JSON.stringify(stats) %>;
    function drawLineChart() {
      const canvas = document.getElementById('lineChart');
      const ctx = canvas.getContext('2d');
      const values = stats.line.leads;
      const apps = stats.line.applications;
      const max = Math.max(1, ...values, ...apps);
      ctx.clearRect(0,0,canvas.width,canvas.height);
      ctx.strokeStyle = 'rgba(255,255,255,.12)';
      for (let i = 0; i < 5; i++) { const y = 35 + i * 50; ctx.beginPath(); ctx.moveTo(40,y); ctx.lineTo(canvas.width - 20,y); ctx.stroke(); }
      function line(data, color) {
        ctx.strokeStyle = color; ctx.lineWidth = 4; ctx.beginPath();
        data.forEach((value, index) => { const x = 50 + index * ((canvas.width - 90) / (data.length - 1)); const y = 250 - (value / max) * 200; index ? ctx.lineTo(x,y) : ctx.moveTo(x,y); });
        ctx.stroke();
      }
      line(values, '#00c896'); line(apps, '#4f8cff');
      ctx.fillStyle = '#9fb5ca'; ctx.font = '13px Arial'; stats.line.labels.forEach((label, index) => ctx.fillText(label, 44 + index * ((canvas.width - 90) / (stats.line.labels.length - 1)), 285));
    }
    function drawPieChart() {
      const canvas = document.getElementById('pieChart');
      const ctx = canvas.getContext('2d');
      const values = stats.pie.values.length ? stats.pie.values : [1];
      const labels = stats.pie.labels.length ? stats.pie.labels : ['No data'];
      const colors = ['#00c896','#4f8cff','#ffca66','#ff7b7b','#b18cff','#59d4ff'];
      const total = values.reduce((sum, value) => sum + value, 0);
      let start = -Math.PI / 2;
      values.forEach((value, index) => { const angle = (value / total) * Math.PI * 2; ctx.beginPath(); ctx.moveTo(150,130); ctx.fillStyle = colors[index % colors.length]; ctx.arc(150,130,95,start,start+angle); ctx.fill(); start += angle; });
      ctx.font = '12px Arial'; labels.forEach((label, index) => { ctx.fillStyle = colors[index % colors.length]; ctx.fillRect(260,70+index*24,10,10); ctx.fillStyle = '#d8e7f7'; ctx.fillText(label.slice(0,24),276,80+index*24); });
    }
    drawLineChart(); drawPieChart();
  </script>
</body>
</html>
