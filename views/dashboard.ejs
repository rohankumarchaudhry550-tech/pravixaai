<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Pravixa AI</title>
  <style>
    body{margin:0;font-family:Inter,sans-serif;background:#070b13;color:#f0f7ff;}
    .topbar{display:flex;justify-content:space-between;align-items:center;padding:24px 32px;background:#08111f;border-bottom:1px solid rgba(255,255,255,0.08);}
    .topbar h1{margin:0;font-size:1.7rem;color:#00c896;}
    .topbar a{color:#fff;text-decoration:none;background:rgba(255,255,255,0.08);padding:10px 18px;border-radius:999px;}
    .content{padding:32px;max-width:1200px;margin:0 auto;}
    .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;margin-bottom:32px;}
    .card{background:rgba(255,255,255,0.04);border:1px solid rgba(0,200,150,0.15);border-radius:24px;padding:24px;}
    .card h2{margin:0 0 10px;color:#00c896;}
    .card p{margin:0;color:#c8e1ff;line-height:1.7;}
    table{width:100%;border-collapse:collapse;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:18px;overflow:hidden;}
    th,td{padding:16px; text-align:left; border-bottom:1px solid rgba(255,255,255,0.08);}
    th{background:rgba(0,200,150,0.12);color:#fff;}
    tr:hover{background:rgba(255,255,255,0.03);}
    .section-title{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;}
    .section-title h2{margin:0;font-size:1.25rem;color:#fff;}
    .actions a{margin-left:12px;color:#00c896;text-decoration:none;}
  </style>
</head>
<body>
  <div class="topbar">
    <h1>Pravixa AI Admin</h1>
    <div>
      <a href="/admin/dashboard">Dashboard</a>
      <a href="/admin/contacts">Contacts</a>
      <a href="/admin/applications">Applications</a>
      <a href="/admin/logout">Logout</a>
    </div>
  </div>
  <div class="content">
    <div class="stats">
      <div class="card">
        <h2>Total leads</h2>
        <p><%= contactsCount %> submission<%= contactsCount === 1 ? '' : 's' %> collected.</p>
      </div>
      <div class="card">
        <h2>Applications</h2>
        <p><%= applicationCount %> applicant<%= applicationCount === 1 ? '' : 's' %> received.</p>
      </div>
      <div class="card">
        <h2>Pages managed</h2>
        <p><%= pages.length %> site pages are available for backend routing.</p>
      </div>
    </div>

    <div class="section-title">
      <h2>Recent leads</h2>
      <div class="actions"><a href="/admin/contacts">View all</a></div>
    </div>
    <% if (recentContacts.length === 0) { %>
      <div class="card"><p>No leads yet. Visitors can submit the contact form on your live site.</p></div>
    <% } else { %>
      <table>
        <thead>
          <tr><th>Date</th><th>Name</th><th>Email</th><th>Service</th></tr>
        </thead>
        <tbody>
          <% recentContacts.forEach(contact => { %>
            <tr>
              <td><%= new Date(contact.createdAt).toLocaleString() %></td>
              <td><%= contact.name %></td>
              <td><%= contact.email %></td>
              <td><%= contact.service || '—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

    <div class="section-title" style="margin-top:40px;">
      <h2>Recent applications</h2>
      <div class="actions"><a href="/admin/applications">View all</a></div>
    </div>
    <% if (recentApplications.length === 0) { %>
      <div class="card"><p>No applications yet. Candidates can submit from the careers page.</p></div>
    <% } else { %>
      <table>
        <thead>
          <tr><th>Date</th><th>Name</th><th>Email</th><th>Role</th></tr>
        </thead>
        <tbody>
          <% recentApplications.forEach(application => { %>
            <tr>
              <td><%= new Date(application.createdAt).toLocaleString() %></td>
              <td><%= application.name %></td>
              <td><%= application.email %></td>
              <td><%= application.role %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

    <div class="section-title" style="margin-top:40px;">
      <h2>Site pages currently available</h2>
      <div class="actions"><a href="/admin/dashboard">Refresh</a></div>
    </div>
    <% if (pages.length === 0) { %>
      <div class="card"><p>No site pages are configured yet. Add or edit on the file system under <code>data/site.json</code>.</p></div>
    <% } else { %>
      <table>
        <thead>
          <tr><th>Route</th><th>Title</th></tr>
        </thead>
        <tbody>
          <% pages.forEach(page => { %>
            <tr>
              <td><a style="color:#00c896; text-decoration:none;" href="<%= page.route %>"><%= page.route %></a></td>
              <td><%= page.title %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
