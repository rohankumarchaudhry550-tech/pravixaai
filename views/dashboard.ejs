<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Pravixa AI</title>
      <link rel="icon" href="fa.png" type="image/png">

  <style>
  *,
*::before,
*::after {
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: Inter, sans-serif;
  background: radial-gradient(circle at top left, #0a1628, #050a14);
  color: #f0f7ff;
  overflow-x: hidden;
}

/* TOPBAR */
.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18px 20px;
  background: rgba(8,17,31,0.85);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(255,255,255,0.08);
  position: sticky;
  top: 0;
  z-index: 100;
}

.topbar h1 {
  margin: 0;
  font-size: 1.5rem;
  color: #00c896;
}

.topbar div {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.topbar a {
  padding: 8px 14px;
  border-radius: 999px;
  text-decoration: none;
  color: white;
  background: rgba(255,255,255,0.08);
  transition: 0.3s;
}

.topbar a:hover {
  background: #00c896;
  color: #06111d;
}

/* CONTENT */
.content {
  max-width: 1200px;
  margin: auto;
  padding: 24px 16px;
}

/* STATS */
.stats {
  display: grid;
  grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
  gap: 20px;
  margin-bottom: 30px;
}

.card {
  background: rgba(255,255,255,0.05);
  border-radius: 20px;
  padding: 20px;
  border: 1px solid rgba(0,200,150,0.2);
  backdrop-filter: blur(10px);
  transition: 0.3s;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, transparent, rgba(0,200,150,0.15), transparent);
  opacity: 0;
  transition: 0.4s;
}

.card:hover::before {
  opacity: 1;
}

.card:hover {
  transform: translateY(-6px) scale(1.01);
}

.card h2 {
  margin: 0 0 8px;
  color: #00c896;
}

.card p {
  margin: 0;
  color: #c8e1ff;
}

/* TABLE */
table {
  width: 100%;
  border-collapse: collapse;
  border-radius: 16px;
  overflow: hidden;
  background: rgba(255,255,255,0.04);
  backdrop-filter: blur(8px);
}

th, td {
  padding: 14px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}

th {
  background: rgba(0,200,150,0.12);
}

tr {
  transition: 0.2s;
}

tr:hover {
  background: rgba(255,255,255,0.05);
  transform: scale(1.01);
}

/* SECTION TITLE */
.section-title {
  display: flex;
  justify-content: space-between;
  margin-bottom: 14px;
}

.section-title h2 {
  margin: 0;
}

.actions a {
  color: #00c896;
  text-decoration: none;
}

/* MOBILE */
@media(max-width:490px){

  .topbar {
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .stats {
    grid-template-columns: 1fr;
  }

  table {
    font-size: 0.85rem;
  }

  th, td {
    padding: 10px;
  }
}
  </style>
</head>
<body>
  <div class="topbar">
    <h1>Pravixa AI Admin</h1>
    <div>
      <a href="/admin/dashboard">Dashboard</a>
      <a href="/admin/contacts">Contacts</a>
      <a href="/admin/applications">Applications</a>
      <a href="/admin/logout">Logout</a>
    </div>
  </div>
  <div class="content">
    <div class="stats">
      <div class="card">
        <h2>Total leads</h2>
        <p><%= contactsCount %> submission<%= contactsCount === 1 ? '' : 's' %> collected.</p>
      </div>
      <div class="card">
        <h2>Applications</h2>
        <p><%= applicationCount %> applicant<%= applicationCount === 1 ? '' : 's' %> received.</p>
      </div>
      <div class="card">
        <h2>Pages managed</h2>
        <p><%= pages.length %> site pages are available for backend routing.</p>
      </div>
    </div>

    <div class="section-title">
      <h2>Recent leads</h2>
      <div class="actions"><a href="/admin/contacts">View all</a></div>
    </div>
    <% if (recentContacts.length === 0) { %>
      <div class="card"><p>No leads yet. Visitors can submit the contact form on your live site.</p></div>
    <% } else { %>
      <table>
        <thead>
          <tr><th>Date</th><th>Name</th><th>Email</th><th>Phone</th><th>Service</th></tr>
        </thead>
        <tbody>
          <% recentContacts.forEach(contact => { %>
            <tr>
              <td><%= new Date(contact.createdAt).toLocaleString() %></td>
              <td><%= contact.name %></td>
              <td><%= contact.email %></td>
              <td><%= contact.phone || '—' %></td>
              <td><%= contact.service || '—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

    <div class="section-title" style="margin-top:40px;">
      <h2>Recent applications</h2>
      <div class="actions"><a href="/admin/applications">View all</a></div>
    </div>
    <% if (recentApplications.length === 0) { %>
      <div class="card"><p>No applications yet. Candidates can submit from the careers page.</p></div>
    <% } else { %>
      <table>
        <thead>
          <tr><th>Date</th><th>Name</th><th>Email</th><th>Role</th><th>Resume</th></tr>
        </thead>
        <tbody>
          <% recentApplications.forEach(application => { %>
            <tr>
              <td><%= new Date(application.createdAt).toLocaleString() %></td>
              <td><%= application.name %></td>
              <td><%= application.email %></td>
              <td><%= application.role %></td>
              <td>
                <% if (application.resumePath) { %>
                  <a style="color:#00c896; text-decoration:none;" href="<%= application.resumePath %>" target="_blank" rel="noopener"><%= application.resumeOriginalName || 'Download' %></a>
                <% } else { %>
                  —
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

    <div class="section-title" style="margin-top:40px;">
      <h2>Site pages currently available</h2>
      <div class="actions"><a href="/admin/dashboard">Refresh</a></div>
    </div>
    <% if (pages.length === 0) { %>
      <div class="card"><p>No site pages are configured yet. Add or edit on the file system under <code>data/site.json</code>.</p></div>
    <% } else { %>
      <table>
        <thead>
          <tr><th>Route</th><th>Title</th></tr>
        </thead>
        <tbody>
          <% pages.forEach(page => { %>
            <tr>
              <td><a style="color:#00c896; text-decoration:none;" href="<%= page.route %>"><%= page.route %></a></td>
              <td><%= page.title %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
