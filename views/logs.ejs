<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Admin Logs | Pravixa AI</title><link rel="icon" href="/fa.png"><style>body{margin:0;font-family:Inter,Arial,sans-serif;background:#07111d;color:#eef7ff}.app{display:grid;grid-template-columns:260px 1fr;min-height:100vh}.sidebar{background:#081827;padding:24px}.brand{display:flex;gap:12px;align-items:center;margin-bottom:28px}.brand img{height:42px}.nav{display:grid;gap:8px}.nav a{color:#bcd0e5;text-decoration:none;padding:12px 14px;border-radius:12px}.nav a.active,.nav a:hover{background:rgba(0,200,150,.14);color:#fff}.main{padding:28px}.panel{background:#0d1d31;border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:18px;overflow:auto}table{width:100%;border-collapse:collapse}th,td{padding:11px;border-bottom:1px solid rgba(255,255,255,.08);text-align:left;vertical-align:top}.muted{color:#98adc3}.level{font-weight:800;text-transform:uppercase}@media(max-width:900px){.app{grid-template-columns:1fr}.main{padding:18px}}</style></head><body><div class="app"><aside class="sidebar"><div class="brand"><img src="/logo.png" alt="Pravixa AI Logo"><strong>Pravixa AI</strong></div><nav class="nav"><a href="/admin/dashboard">Dashboard</a><a href="/admin/contacts">Leads</a><a href="/admin/applications">Applications</a><a href="/admin/users">Users</a><a class="active" href="/admin/logs">Logs</a><a href="/admin/settings">Settings</a><a href="/admin/logout">Logout</a></nav></aside><main class="main"><h1>Logs</h1><p class="muted">Recent backend events for debugging and audit review.</p><section class="panel"><table><thead><tr><th>Time</th><th>Level</th><th>Event</th><th>Details</th></tr></thead><tbody><% logs.forEach(log => { %><tr><td><%= log.time ? new Date(log.time).toLocaleString() : '' %></td><td class="level"><%= log.level %></td><td><%= log.message %></td><td><%= JSON.stringify(Object.fromEntries(Object.entries(log).filter(([key]) => !['time','level','message'].includes(key)))) %></td></tr><% }) %></tbody></table></section></main></div></body></html>
