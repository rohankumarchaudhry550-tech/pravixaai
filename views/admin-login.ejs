<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Sign In | Pravixa AI</title>
  <link rel="icon" href="/fa.png" type="image/png">
  <style>
    body{margin:0;min-height:100vh;display:grid;place-items:center;background:#07111d;color:#eef7ff;font-family:Inter,Arial,sans-serif;padding:20px;}
    main{width:min(100%,440px);background:#0c1a2c;border:1px solid rgba(255,255,255,.1);border-radius:18px;padding:30px;box-shadow:0 28px 90px rgba(0,0,0,.35);}
    .brand{display:flex;align-items:center;gap:12px;margin-bottom:24px;}
    .brand img{height:44px;}
    h1{margin:0 0 8px;font-size:2rem;}
    p{margin:0 0 22px;color:#a9bdd3;line-height:1.6;}
    label{display:block;margin:14px 0 7px;color:#d6e6f5;}
    input{width:100%;box-sizing:border-box;padding:13px 14px;border-radius:12px;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.05);color:#fff;font-size:1rem;}
    input:focus{outline:none;border-color:#00c896;box-shadow:0 0 0 4px rgba(0,200,150,.12);}
    button{width:100%;margin-top:20px;padding:14px;border:0;border-radius:12px;background:#00c896;color:#06111d;font-weight:800;cursor:pointer;}
    .error{padding:12px 14px;border-radius:12px;background:rgba(255,91,91,.15);border:1px solid rgba(255,91,91,.3);color:#ffcaca;margin-bottom:16px;}
    a{color:#00c896;text-decoration:none;}
  </style>
</head>
<body>
  <main>
    <div class="brand"><img src="/logo.png" alt="Pravixa AI Logo"><strong></strong></div>
    <h1>Secure Sign In</h1>
    <p>Use your admin email and password. Sessions expire automatically for security.</p>
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <form method="post" action="/admin/login">
      <label for="username">Admin email</label>
      <input id="username" name="username" type="email" autocomplete="username" required>
      <label for="password">Password</label>
      <input id="password" name="password" type="password" autocomplete="current-password" required>
      <button type="submit">Sign In</button>
    </form>
    <p style="margin-top:18px;"><a href="/">Back to website</a></p>
  </main>
</body>
</html>
